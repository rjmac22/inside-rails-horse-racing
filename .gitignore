# Source and generated data
/data/raw/*
/data/interim/*
/data/processed/*
/data/external/*
/db/*

# Keep directory structure
!/data/raw/.gitkeep
!/data/interim/.gitkeep
!/data/processed/.gitkeep
!/data/external/.gitkeep
!/db/.gitkeep

# Database and large data files
*.sqlite
*.sqlite3
*.db
*.csv
*.csv.gz
*.parquet
*.feather
*.pkl
*.zip
*.7z
*.tar
*.tar.gz

# Python
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Environment and secrets
.env
.env.*
!.env.example

# Editors and operating systems
.vscode/
.idea/
.DS_Store
Thumbs.db
